# Copy to .env (same directory as docker-compose.yml). Never commit .env.

# One LLM key shared by every agent container (compute happens at the API).
LLM_KEY=sk-ant-...

# Optional: an embedding endpoint reachable from this box. When set, each
# container's `brain index` builds semantic (not just keyword) indexes.
EMBED_URL=

# One bot token per person (@BotFather → /newbot).
ALICE_BOT_TOKEN=123456789:ABC...
# BOB_BOT_TOKEN=...
