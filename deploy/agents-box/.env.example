# Copy to .env (same directory as docker-compose.yml). Never commit .env.

# One LLM key shared by every agent container (compute happens at the API).
LLM_KEY=sk-ant-...

# Optional: an embedding endpoint reachable from this box. When set, each
# container's `brain index` builds semantic (not just keyword) indexes.
# Any OpenAI-compatible /embeddings endpoint works (a provider directly, or a
# gateway such as Vercel AI Gateway: https://ai-gateway.vercel.sh/v1).
# Verify the dimension your model actually returns with one curl before
# picking EMBED_DIM — some gateways ignore the `dimensions` parameter for
# some providers. Model/dim default to text-embedding-3-small / 512.
EMBED_URL=
EMBED_API_KEY=
EMBED_MODEL=
EMBED_DIM=

# One bot token per person (@BotFather → /newbot).
ALICE_BOT_TOKEN=123456789:ABC...
# BOB_BOT_TOKEN=...
